{
  "compilerOptions": {
    "declaration": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2019"
  },
  "include": ["*.ts", "*.tsx"],
  "exclude": ["*.test.ts", "dist", "node_modules"]
}
